{
  "entities": {
    "ScanResult": {
      "title": "ScanResult",
      "description": "Represents a threat scan result.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "verdict": { "type": "string", "enum": ["REAL", "FAKE", "GENUINE", "SUSPICIOUS", "SAFE", "DANGEROUS", "CLONED"] },
        "confidence": { "type": "number" },
        "trust_score": { "type": "number", "description": "0-100, 100 = fully trustworthy/safe" },
        "confidence_band": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "threat_level": { "type": "string", "enum": ["SAFE", "LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "red_flags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "description": "Structured explainability evidence behind the verdict",
          "items": {
            "type": "object",
            "properties": {
              "category": { "type": "string", "enum": ["visual", "audio", "text", "metadata", "network"] },
              "finding": { "type": "string" },
              "severity": { "type": "string", "enum": ["low", "medium", "high"] },
              "location": { "type": "string" }
            }
          }
        },
        "explanation_english": { "type": "string" },
        "explanation_hindi": { "type": "string" },
        "recommendation": { "type": "string" },
        "scam_type": { "type": "string" },
        "impersonating": { "type": "string" }
      },
      "required": ["id", "userId", "type", "date", "verdict", "confidence", "trust_score", "confidence_band", "threat_level", "red_flags", "explanation_english", "recommendation"]
    }
  },
  "firestore": {
    "/scans/{scanId}": {
      "schema": { "$ref": "#/entities/ScanResult" },
      "description": "A collection of user-initiated threat scan results."
    }
  }
}
