# --- Server-side only (read by server/index.ts; NEVER exposed to the browser) ---

# GEMINI_API_KEY: required for all /api/analyze/* calls.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# PORT: port the Express API serveni_api_key_herer listens on. Vite's dev proxy targets this.
PORT=8787

# ALLOWED_ORIGIN: restricts CORS to this origin. Use '*' to allow all (not recommended in prod).
ALLOWED_ORIGIN="http://localhost:3000"

# RATE_LIMIT_MAX: max requests per 15-minute window per IP for /api/* routes.
RATE_LIMIT_MAX=50

# GEMINI_MODEL: which Gemini model to use. Change for testing or cost optimization.
GEMINI_MODEL="gemini-2.5-flash"

# --- Client-side (must be prefixed VITE_ to be exposed to the browser by Vite) ---
# Optional: enables cloud-synced scan history via Firebase Auth (anonymous) + Firestore.
# Leave unset to fall back to per-device localStorage history (no setup required).
# Get these from your Firebase project settings > General > Your apps > Web app.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Optional: only needed if the API server is deployed somewhere other than
# the same origin (e.g. a separate Cloud Run service in production).
# VITE_API_BASE_URL="https://api.your-deployment.com/api"
