rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidEvidenceItem(item) {
      return item is map &&
             item.keys().hasAll(['category', 'finding', 'severity']) &&
             item.category in ['visual', 'audio', 'text', 'metadata', 'network'] &&
             item.finding is string && item.finding.size() <= 500 &&
             item.severity in ['low', 'medium', 'high'] &&
             (!('location' in item) || (item.location is string && item.location.size() <= 200));
    }

    function isValidEvidence(data) {
      return !('evidence' in data) ||
             (data.evidence is list && data.evidence.size() <= 20 &&
              (data.evidence.size() == 0 || isValidEvidenceItem(data.evidence[0])));
    }

    function isValidScanResult(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'date', 'verdict', 'confidence', 'trust_score', 'confidence_band', 'threat_level', 'red_flags', 'explanation_english', 'recommendation']) &&
             data.keys().size() >= 12 && data.keys().size() <= 16 &&
             data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.type is string && data.type.size() <= 128 &&
             data.date is string && data.date.size() <= 128 &&
             data.verdict in ['REAL', 'FAKE', 'GENUINE', 'SUSPICIOUS', 'SAFE', 'DANGEROUS', 'CLONED'] &&
             data.confidence is number && data.confidence >= 0 && data.confidence <= 100 &&
             data.trust_score is number && data.trust_score >= 0 && data.trust_score <= 100 &&
             data.confidence_band in ['LOW', 'MEDIUM', 'HIGH'] &&
             data.threat_level in ['SAFE', 'LOW', 'MEDIUM', 'HIGH', 'CRITICAL'] &&
             data.red_flags is list && data.red_flags.size() <= 20 && (data.red_flags.size() == 0 || data.red_flags[0] is string) &&
             data.explanation_english is string && data.explanation_english.size() <= 5000 &&
             data.recommendation is string && data.recommendation.size() <= 5000 &&
             (!('explanation_hindi' in data) || (data.explanation_hindi is string && data.explanation_hindi.size() <= 5000)) &&
             (!('scam_type' in data) || (data.scam_type is string && data.scam_type.size() <= 128)) &&
             (!('impersonating' in data) || (data.impersonating is string && data.impersonating.size() <= 128)) &&
             isValidEvidence(data);
    }

    match /scans/{scanId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(scanId) && isValidScanResult(incoming());
      // Re-evaluate on update, but do we need to allow updates? Our app only creates. If so we can deny update.
      allow update: if false;
      allow delete: if isSignedIn() && isValidId(scanId) && existing().userId == request.auth.uid;
    }
  }
}
